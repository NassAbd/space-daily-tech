# =============================================================================
# Space Daily Tech — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# Google Gemini API Key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) TTS Voice: Charon (default, male) | Kore | Aoede | Lede
TTS_VOICE_NAME=Charon

# (Optional) Max number of articles to process (default: 10)
MAX_ARTICLES=10

# (Optional) Briefing topic (e.g., Space Tech)
TOPIC_NAME="Space Tech"

# (Optional) RSS Feed URL (default: CNES Actualités)
RSS_FEED_URL=https://cnes.fr/rss/actualites

# (Optional) Email Alert Configurations (For workflow use)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_TO=recipient_email@gmail.com
